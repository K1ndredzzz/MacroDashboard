# Macro Dashboard Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# PostgreSQL Database
# ============================================================================
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=macro_dashboard
POSTGRES_USER=macro_user
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# FRED API
# ============================================================================
# Get your API key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ============================================================================
# Frontend Configuration
# ============================================================================
# For local development
FRONTEND_API_URL=http://localhost:8000

# For production (use your server's IP or domain)
# FRONTEND_API_URL=http://your-server-ip:8000

# ============================================================================
# Data Collection Schedule
# ============================================================================
# Cron format: minute hour day month weekday
# Default: Every 6 hours
CRON_SCHEDULE=0 */6 * * *

# ============================================================================
# Optional: GCP (only needed for data migration)
# ============================================================================
# GCP_PROJECT_ID=gen-lang-client-0815236933
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
