# Cloud Functions Environment Variables
# Copy this to .env and fill in your values

# FRED API (Required)
FRED_API_KEY=your_fred_api_key_here

# GCP Settings
GCP_PROJECT_ID=gen-lang-client-0815236933
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# BigQuery
BQ_DATASET_RAW=macro_raw
BQ_DATASET_CORE=macro_core
BQ_DATASET_OPS=macro_ops

# Cloud Storage
GCS_BUCKET_RAW=macro-dashboard-raw
